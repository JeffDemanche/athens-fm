# syntax=docker/dockerfile:1

FROM node:22-bookworm AS base
WORKDIR /app

COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/
COPY apps/api/package.json ./apps/api/

RUN npm ci

COPY . .

FROM base AS api
EXPOSE 3001
CMD ["npm", "run", "dev", "-w", "@athens-fm/api"]

FROM base AS web
EXPOSE 5173
CMD ["npm", "run", "dev", "-w", "@athens-fm/web", "--", "--host", "0.0.0.0", "--port", "5173"]
