# Host ports (override if something else already owns the defaults)
WEB_HOST_PORT=5173
API_HOST_PORT=3001

# Server (used by host-side / optional overrides; Docker Compose sets service URLs)
PORT=3001
CORS_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/athens-fm
REDIS_URL=redis://127.0.0.1:6379

# YouTube Data API v3 (server-side metadata: title, thumbnails, …)
YOUTUBE_API_KEY=

# Frontend (Vite)
VITE_API_URL=
VITE_API_PROXY_TARGET=http://localhost:3001
VITE_GRAPHQL_URL=/api/graphql
