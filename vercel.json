{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "fluid": true,
  "buildCommand": "npm run build -w @athens-fm/web",
  "outputDirectory": "apps/web/dist",
  "installCommand": "npm install --include=dev --workspaces -w @athens-fm/web -w @athens-fm/api",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
